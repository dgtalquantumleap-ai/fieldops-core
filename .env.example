# FieldOps Core - Environment Variables
# Copy this file to .env and fill in your values.
# This app uses PostgreSQL (e.g. Railway Postgres addon).

# ============================================
# BUSINESS BRANDING (REQUIRED — change per client)
# ============================================
BUSINESS_NAME=Your Business Name
BUSINESS_PHONE=+1-555-000-0000
BUSINESS_EMAIL=info@yourbusiness.com
BUSINESS_CITY=Your City, Province/State
BUSINESS_WEBSITE=www.yourbusiness.com
BUSINESS_TAGLINE=Professional Services
BUSINESS_INDUSTRY=Cleaning Services
BUSINESS_OWNER_NAME=Jane Smith
BUSINESS_OWNER_INITIALS=JS
BUSINESS_FOUNDED_YEAR=2020
BUSINESS_SERVICE_AREA=our city and surrounding areas

# ============================================
# SERVER
# ============================================
PORT=3000
NODE_ENV=production
APP_URL=https://your-railway-app.up.railway.app

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://your-railway-app.up.railway.app,http://localhost:3000

# ============================================
# DATABASE (REQUIRED)
# ============================================
# PostgreSQL connection string (Railway, Supabase, Neon, etc.)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ============================================
# AUTHENTICATION (REQUIRED)
# ============================================
# Must be 32+ characters, completely random
JWT_SECRET=replace_this_with_a_random_64_character_string_do_not_use_this_value

# Used by /api/auth/create-admin to bootstrap the first admin account
# Set this, hit the endpoint once, then remove or rotate it
SETUP_SECRET=another_random_secret_for_one_time_admin_setup

# Auto-creates the first admin user on startup if no admin exists
ADMIN_EMAIL=yourname@gmail.com
ADMIN_PASSWORD=ChangeThisSecurePassword123!
ADMIN_PHONE=+1-555-000-0000

# ============================================
# EMAIL — Gmail (REQUIRED for notifications)
# ============================================
# Use a Gmail App Password (not your real password):
# Google Account → Security → 2-Step Verification → App Passwords
EMAIL_USER=yourname@gmail.com
EMAIL_PASS=your_gmail_app_password_16_chars
ADMIN_EMAIL=yourname@gmail.com

# ============================================
# WEB PUSH NOTIFICATIONS (FREE — no Twilio)
# ============================================
# Generate keys once:
#   node -e "const wp=require('web-push'); console.log(wp.generateVAPIDKeys())"
VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here
VAPID_EMAIL=mailto:yourname@gmail.com

# ============================================
# AI FEATURES (OPTIONAL)
# ============================================
# Free tier available at huggingface.co
# If not set, AI features degrade gracefully to plain-text templates
HUGGING_FACE_API_KEY=hf_your_key_here
HUGGING_FACE_MODEL=mistralai/Mistral-7B-Instruct-v0.2
